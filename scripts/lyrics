#!/usr/bin/env bash
# figlet lyrics via sptlrx pipe

old_stty=$(stty -g < /dev/tty)

cleanup() {
    kill "$KEY_PID" 2>/dev/null
    stty "$old_stty" < /dev/tty
    printf '\033[?25h'
    tput rmcup
    exit 0
}
trap cleanup EXIT SIGINT SIGTERM

tput smcup
printf '\033[H\033[2J\033[?25l'
stty -echo -icanon < /dev/tty

# q to quit
( while IFS= read -r -n1 key < /dev/tty; do
    [[ "$key" == "q" || "$key" == "Q" ]] && kill -SIGINT $$
done ) &
KEY_PID=$!

LYRIC_COLOR="#FFFFFF"
color_mtime=0
reload_color() {
    local f="$HOME/.config/sptlrx/lyric-color.env"
    [[ ! -f "$f" ]] && return
    local mt
    mt=$(stat -c %Y "$f" 2>/dev/null)
    [[ "$mt" == "$color_mtime" ]] && return
    source "$f"
    color_mtime="$mt"
}
reload_color

COLS=$(tput cols)
ROWS=$(tput lines)
last_line="" last_cols=0 last_rows=0 cur_line=""

render() {
    local line="$1"
    [[ "$line" == "$last_line" && "$COLS" == "$last_cols" && "$ROWS" == "$last_rows" ]] && return
    reload_color
    last_line="$line"; last_cols=$COLS; last_rows=$ROWS

    local rendered
    rendered=$(figlet -c -w "$COLS" "$line")

    # count lines without subprocess
    local no_nl="${rendered//$'\n'/}"
    local line_count=$(( ${#rendered} - ${#no_nl} ))
    [[ $line_count -lt 1 ]] && line_count=1

    local padding=$(( (ROWS - line_count) / 2 ))
    [[ $padding -lt 0 ]] && padding=0

    # hex to rgb
    local hex="${LYRIC_COLOR#\#}"
    local r=$((16#${hex:0:2})) g=$((16#${hex:2:2})) b=$((16#${hex:4:2}))

    local pad='' i
    for ((i=0; i<padding; i++)); do pad+=$'\n'; done

    # write
    printf '\033[H\033[2J%s\033[38;2;%d;%d;%dm%s\033[0m' \
        "$pad" "$r" "$g" "$b" "$rendered"
}

on_resize() {
    COLS=$(tput cols)
    ROWS=$(tput lines)
    last_line=""
    [[ -n "$cur_line" ]] && render "$cur_line"
}
trap on_resize SIGWINCH

showing=false
while IFS= read -r line; do
    if [[ -z "$line" ]]; then
        if $showing; then
            printf '\033[H\033[2J'
            showing=false
            cur_line="" last_line=""
        fi
        continue
    fi
    showing=true
    cur_line="$line"
    render "$line"
done < <(sptlrx pipe)

{
    "$schema": "/etc/xdg/swaync/configSchema.json",
    "positionX": "right",
    "positionY": "top",
    "layer": "overlay",
    "control-center-layer": "top",
    "layer-shell": true,
    "layer-shell-cover-screen": true,
    "cssPriority": "user",
    "ignore-gtk-theme": true,

    "control-center-margin-top": 5,
    "control-center-margin-bottom": 5,
    "control-center-margin-right": 5,
    "control-center-margin-left": 0,

    "timeout": 10,
    "timeout-low": 5,
    "timeout-critical": 0,

    "fit-to-screen": true,
    "relative-timestamps": true,

    "control-center-width": 350,
    "notification-window-width": 350,

    "keyboard-shortcuts": true,
    "notification-grouping": true,
    "image-visibility": "when-available",
    "transition-time": 200,

    "hide-on-clear": false,
    "hide-on-action": true,

    "text-empty": "No Notifications",
    "script-fail-notify": true,

    "widgets": [
        "title",
        "dnd",
        "buttons-grid",
        "volume",
        "backlight",
        "notifications"
    ],

    "widget-config": {

        "title": {
            "text": "Notifications",
            "clear-all-button": true,
            "button-text": "Clear"
        },

        "dnd": {
            "label": "󰂛"
        },

        "volume": {
            "label": "󰕾"
        },

        "backlight": {
            "label": ""
        },

        "notifications": {
            "vexpand": true
        },

        "buttons-grid": {
            "buttons-per-row": 6,
            "actions": [
                {
                    "label": "󰐥",
                    "type": "button",
                    "command": "wlogout"
                },
                {
                    "label": "",
                    "type": "button",
                    "command": "nm-connection-editor"
                },
                {
                    "label": "󰂯",
                    "type": "button",
                    "command": "uwsm-app -- blueman-manager"
                },
                {
                    "label": "󰕾",
                    "type": "button",
                    "command": "uwsm-app -- pavucontrol"
                },
                {
                    "label": "",
                    "type": "toggle",
                    "active": "~/.local/bin/caffeine_status.sh",
                    "command": "~/.local/bin/caffeine_toggle.sh"
                }
            ]
        }
    }
}

[Desktop Entry]
Type=Application
Name=Wallpaper Picker
Comment=Select a wallpaper from a visual grid
Exec=bash -c 'exec uwsm-app -- ~/.local/bin/rofi_wallpaper_selector.sh'
Terminal=false
Categories=Settings;DesktopSettings;
Keywords=wallpaper;background;theme;picker;
Icon=preferences-desktop-wallpaper
StartupNotify=false

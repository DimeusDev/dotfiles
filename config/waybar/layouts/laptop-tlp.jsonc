/* Laptop + TLP using battery#tlp */
{
"group/system": {
	"orientation": "horizontal",
	"modules": ["cpu", "memory", "temperature", "tray"],
	"on-scroll-up": "true",
	"on-scroll-down": "true"
},

"modules-left":   ["custom/arch", "battery#tlp", "hyprland/workspaces#rw", "mpris", "custom/cava_mviz"],
"modules-center": ["clock"],
"modules-right":  ["network", "bluetooth", "pulseaudio", "group/system", "custom/swaync"]
}

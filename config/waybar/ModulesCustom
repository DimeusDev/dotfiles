/* Waybar Modules - Custom Modules */
/* Basically created to reduce the lines in Waybar Modules bank */
/* NOTE: This is only for Custom Modules */
/* Custom Modules like weather browser, tty, file manager at the beginning */

{
"custom/arch": {
	"tooltip": false,
	"format": "󰣇",
	"on-click": "$HOME/.config/eww/scripts/toggle.sh",
	"menu": "on-click-right",
	"menu-file": "$HOME/.config/waybar/context/arch_menu.xml",
	"menu-actions": {
		"terminal": "kitty",
		"power": "$HOME/.local/bin/logout.sh",
		"gtk": "nwg-look"
	}
},

"custom/window-media": {
	"exec": "$HOME/user_scripts/waybar/window-media.sh",
	"return-type": "json",
	"format": "{}",
	"interval": 1,
	"max-length": 60,
	"on-click": "playerctl play-pause",
	"escape": false
},

"custom/weather": {
	"format": "{}",
	"format-alt": "{alt}: {}",
	"format-alt-click": "click",
	"interval": 3600,
	"return-type": "json",
	"exec": "$HOME/user_scripts/Weather.py",
	//"exec": "$HOME/user_scripts/Weather.sh",
	//"exec-if": "ping wttr.in -c1",
	"tooltip": true,
},

"custom/file_manager": {
	"format": " ",
	"on-click": "xdg-open . &",
	"tooltip": true,
	"tooltip-format": "File Manager",
},

"custom/tty": {
	"format": " ",
	"on-click": "$HOME/user_scripts/WaybarScripts.sh --term",
	"tooltip": true,
	"tooltip-format": "Launch Terminal",
},

"custom/browser": {
	"format": " ",
	"on-click": "xdg-open https://",
	"tooltip": true,
	"tooltip-format": "Launch Browser",
},

"custom/settings": {
	"format": " ",
	"on-click": "$HOME/user_scripts/Kool_Quick_Settings.sh",
	"tooltip": true,
	"tooltip-format": "Launch KooL Hyprland Settings Menu",
},

"custom/cycle_wall": {
	"format": " ",
	"on-click": "$HOME/user_scripts/rofi/rofi_wallpaper_selctor.sh",
	"on-click-right": "$HOME/user_scripts/theme_matugen/random_theme.sh",
	// DISABLED: Missing WaybarStyles.sh
	//"on-click-middle": "$HOME/user_scripts/WaybarStyles.sh",
	"tooltip": true,
	"tooltip-format": "Left Click: Wallpaper Menu\nMiddle Click: Random wallpaper\nRight Click: Waybar Styles Menu",
},


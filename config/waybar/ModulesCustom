// caffeine - hypridle inhibitor
"custom/hypridle": {
	"format": "{}",
	"return-type": "json",
	"escape": true,
	"exec-on-event": true,
	"interval": 60,
	"signal": 9,
	"exec": "$HOME/.local/bin/caffeine_toggle.sh status",
	"on-click": "$HOME/.local/bin/caffeine_toggle.sh",
	"on-click-right": "hyprlock"
},

